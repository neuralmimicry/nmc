{
  "agent_id": {{ nmc_tracey_agent_id | to_json }},
  "discovery": {
    "enabled": true,
    "bind_addr": {{ nmc_tracey_discovery_bind_addr | to_json }},
    "broadcast_addr": {{ nmc_tracey_discovery_broadcast_addr | to_json }},
    "shared_key": {{ nmc_tracey_discovery_shared_key | to_json }}
  },
  "status": {
    "enabled": true,
    "listen_addr": {{ nmc_tracey_status_listen_addr | to_json }},
    "public_addr": {{ nmc_tracey_status_public_addr | to_json }}
  },
  "auth": {
    "mode": {{ nmc_tracey_auth_mode | to_json }},
    "protect_status": {{ (nmc_tracey_auth_protect_status | bool) | to_json }},
    "protect_otlp_http": {{ (nmc_tracey_auth_protect_otlp_http | bool) | to_json }},
    "protect_otlp_grpc": {{ (nmc_tracey_auth_protect_otlp_grpc | bool) | to_json }},
    "token": {
      "session_url": {{ nmc_tracey_auth_session_url | to_json }},
      "static_token": {{ nmc_tracey_auth_token | to_json }},
      "cache_ttl_ms": {{ (nmc_tracey_auth_cache_ttl_ms | int) | to_json }},
      "http_timeout_ms": {{ (nmc_tracey_auth_timeout_ms | int) | to_json }}
    }
  },
  "storage": {
    "log_path": {{ (nmc_tracey_state_dir ~ '/tracey.log.jsonl') | to_json }}
  }
}
