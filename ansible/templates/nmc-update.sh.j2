#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

CONFIG=/etc/nmc/nmc-update.conf
if [[ -f "$CONFIG" ]]; then
  # shellcheck disable=SC1090
  source "$CONFIG"
else
  echo "Update config not found: $CONFIG" >&2
  exit 1
fi

: "${REPO_DIR:?Missing REPO_DIR}"
: "${REPO_BRANCH:=main}"
: "${UPDATE_USER:=nmc}"
: "${INSTALL_MODE:=source}"
: "${PACKAGE_REPO:=neuralmimicry/nmc}"
: "${RUN_USER:=nmc}"
: "${RUN_GROUP:=${RUN_USER}}"
: "${PORT:=8080}"
: "${STATE_DIR:=/var/lib/nmc}"
: "${ENV_FILE:=/etc/nmc/nmc.env}"
: "${KUBECONFIG_PATH:=/etc/nmc/kubeconfig}"

run_as_user() {
  if [[ "$(id -u)" -eq 0 && "$UPDATE_USER" != "root" ]]; then
    if command -v sudo >/dev/null 2>&1; then
      sudo -u "$UPDATE_USER" -H -- "$@"
    else
      runuser -u "$UPDATE_USER" -- "$@"
    fi
  else
    "$@"
  fi
}

git_as_user() {
  run_as_user git -C "$REPO_DIR" "$@"
}

update_remote_url() {
  local origin_url repo_path
  origin_url="$(git_as_user remote get-url origin)"

  if [[ -n "${GITHUB_TOKEN:-}" ]]; then
    case "$origin_url" in
      git@github.com:*)
        repo_path="${origin_url#git@github.com:}"
        printf 'https://x-access-token:%s@github.com/%s\n' "$GITHUB_TOKEN" "$repo_path"
        return
        ;;
      https://github.com/*)
        repo_path="${origin_url#https://github.com/}"
        printf 'https://x-access-token:%s@github.com/%s\n' "$GITHUB_TOKEN" "$repo_path"
        return
        ;;
    esac
  fi

  printf '%s\n' "$origin_url"
}

if [[ -n "$(git_as_user status --porcelain)" ]]; then
  echo "Working tree dirty; skipping update" >&2
  exit 0
fi

REMOTE_URL="$(update_remote_url)"
if ! git_as_user ls-remote --exit-code "$REMOTE_URL" "$REPO_BRANCH" >/dev/null 2>&1; then
  echo "Unable to reach origin branch '$REPO_BRANCH'; skipping update" >&2
  exit 0
fi

git_as_user fetch "$REMOTE_URL" "$REPO_BRANCH"
LOCAL="$(git_as_user rev-parse HEAD)"
REMOTE="$(git_as_user rev-parse FETCH_HEAD)"

if [[ "$LOCAL" == "$REMOTE" ]]; then
  exit 0
fi

git_as_user checkout "$REPO_BRANCH"
git_as_user pull --ff-only "$REMOTE_URL" "$REPO_BRANCH"

if [[ "$INSTALL_MODE" == "package" ]]; then
  release_version="$(tr -d '[:space:]' < "$REPO_DIR/VERSION")"
  [[ -n "$release_version" ]] || {
    echo "VERSION file is empty: $REPO_DIR/VERSION" >&2
    exit 1
  }

  if [[ -n "${GITHUB_TOKEN:-}" ]]; then
    export GITHUB_TOKEN
  fi

  "$REPO_DIR/scripts/install-server.sh" \
    --release-version "$release_version" \
    --repo "$PACKAGE_REPO" \
    --run-user "$RUN_USER" \
    --run-group "$RUN_GROUP" \
    --service-name nmc-server \
    --port "$PORT" \
    --state-dir "$STATE_DIR" \
    --env-file "$ENV_FILE" \
    --kubeconfig "$KUBECONFIG_PATH" \
    --skip-client
else
  run_as_user cmake -S "$REPO_DIR/nmc_server" -B "$REPO_DIR/nmc_server/build" -DCMAKE_BUILD_TYPE=Release
  run_as_user cmake --build "$REPO_DIR/nmc_server/build" -- -j"$(nproc)"

  systemctl restart nmc-server.service
fi
